---
import { getCollection } from "astro:content";
import type { Content } from "../lib/content";
import PostList from "./PostList.astro";

const { content } = Astro.props as { content: Content };

const posts = await getCollection(
  "postCollection",
  ({ data }) =>
    data.type == "project" && data.public === true && data.featured === true,
);
---

<PostList
  title={content.projectFeatured.title}
  subTitle={content.projectFeatured.subTitle}
  posts={posts}
  sectionId="featuredProjects"
/>
