---
import LetsConnect from './LetsConnect.astro';

interface Props {
  bgImg?: string;
  bgAlt?: string;
  avatarImg?: string;
  avatarAlt?: string;
  isDark?: boolean;
  isHeaderDark?: boolean
  letsConnect?: boolean;
  preTitle?: string;
  title: string;
  postTitle?: string;
  subTitle?: string;
}

const {
  bgImg = "",
  bgAlt = "",
  isDark = false,
  isHeaderDark = false,
  avatarAlt,
  avatarImg,
  letsConnect = false,
  preTitle,
  title,
  postTitle,
  subTitle,
} = Astro.props;
---

<section
  id="hero"
  class="relative bg-white bg-cover bg-center bg-no-repeat py-8"
  style={`background-image: url(${bgImg})`}
>
  <!-- BG -->
  <img style="width: 0; height: 0;" src={bgImg} alt={bgAlt} />
  <!-- Gradient overlay -->
  <div
    class={`absolute inset-0 z-20 bg-linear-to-r` +
      (isDark
        ? ` from-hero-gradient-from to-hero-gradient-to`
        : ` from-hero-post-gradient-from to-hero-post-gradient-to`)}
  >
  </div>

  <div
    class="container relative z-30 pt-20 pb-12 sm:pt-56 sm:pb-48 lg:pt-64 lg:pb-48"
  >
    <div class="flex flex-col items-center justify-center lg:flex-row">
      <!-- Avatar -->
      {
        avatarImg && avatarAlt && (
          <div class="rounded-full border-8 border-primary shadow-xl">
            <img
              src={avatarImg}
              class="rounded-full max-w-48 md:max-w-64"
              alt={avatarAlt}
            />
          </div>
        )
      }

      <!-- Text -->
      <div class="pt-8 sm:pt-10 lg:pl-8 lg:pt-0">
        <h1
          class={"text-center font-header text-4xl text-white lg:text-left sm:text-5xl xl:text-6xl" + (isHeaderDark ? "  bg-linear-to-r from-hero-gradient-from to-hero-gradient-to inline-block p-1" : "")}
        >
          {
            preTitle && (
              <small class="text-2xl sm:text-3xl xl:text-4xl font-light">
                {preTitle}
              </small>
              <br />
            )
          }
          {title}
          {
            postTitle && (
              <br />
              <small class="text-2xl sm:text-3xl xl:text-4xl font-light">
                {postTitle}
              </small>
            )
          }
        </h1>
        
        {
          subTitle && (
            <p
              class={"text-center font-header text-2xl text-white lg:text-left sm:text-3xl xl:text-4xl font-extralight italic mt-4" + (isHeaderDark ? " bg-linear-to-r from-hero-gradient-from to-hero-gradient-to p-2" : "")}
            >
              {subTitle}
            </p>
          )
        }

        {letsConnect && <LetsConnect class="pt-3 lg:justify-start" />}
      </div>
    </div>
  </div>
</section>
