---

const variants = {
  primary: "bg-primary text-white hover:bg-primary/90",
  secondary: "bg-secondary text-white hover:bg-secondary/90",
  outline: "border-2 border-primary text-primary hover:bg-primary hover:text-white",
  ghost: "text-primary hover:bg-primary/10",
  yellow: "bg-yellow text-secondary hover:bg-yellow/90",
};

const sizes = {
  sm: "px-3 py-1.5 text-sm",
  md: "px-4 py-2 text-base",
  lg: "px-6 py-3 text-lg",
};

const baseStyles = "inline-flex items-center justify-center font-header font-semibold uppercase tracking-wide transition-colors duration-200 rounded cursor-pointer";

interface Props {
  variant?: keyof typeof variants;
  size?: "sm" | "md" | "lg";
  type?: "button" | "submit" | "reset";
  href?: string;
  class?: string;
  action?: "closeModal" | "scroll" | "openModal";
  target?: string;
  onclick?: string;
}

const {
  variant = "primary",
  size = "md",
  type = "button",
  href,
  class: className = "",
  action,
  target,
  onclick,
} = Astro.props as Props;

const isLink = !!href || action === "scroll";
const dataAttrs = action ? { "data-action": action, ...(target ? { "data-target": target } : {}) } : {};
---

{isLink ? (
  <a
    href={href || (target ? target : "#")}
    class:list={[baseStyles, variants[variant], sizes[size], className]}
    onclick={onclick}
    {...dataAttrs}
  >
    <slot />
  </a>
) : (
  <button
    type={type}
    class:list={[baseStyles, variants[variant], sizes[size], className]}
    onclick={onclick}
    {...dataAttrs}
  >
    <slot />
  </button>
)}
