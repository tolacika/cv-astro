---
import type { Content } from "../lib/content";

const { content } = Astro.props as { content: Content };

const langs = content.intro.langs.items;
---

<section id="languages">
  <h3 class="text-left font-header text-2xl font-semibold uppercase mb-4 text-primary sm:text-3xl lg:text-4xl">
    {content.intro.langs.title}
  </h3>

  <div class="grid grid-cols-1 gap-4">
    {langs.map((lang) => {
      return (
        <div class="mb-2 bg-white p-2 shadow-lg rounded-2xl">
          <div class="mb-2 flex items-end justify-around">
            <h4
              class="font-body font-semibold text-lg md:text-xl text-black whitespace-pre-wrap"
              title={lang.label}
            >
              <span class={`fi fi-${lang.icon} mr-2`}></span>
              {lang.greeting}
            </h4>
            <h3 class="font-body md:text-lg lg:text-xl font-bold text-primary">
              {lang.proficiency}
            </h3>
          </div>

          <p class="font-body italic leading-relaxed text-grey-10 text-center md:text-lg">
            {lang.comment}
          </p>
        </div>
      );
    })}
  </div>
</section>