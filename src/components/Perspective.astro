---
import type { Content } from "../lib/content";
import { getPosts } from "../lib/posts";
import PostList from "./PostList.astro";
const sortOrder = [
  "perspective-background",
  "perspective-vision",
  "perspective-side-quests",
];

const { content } = Astro.props as { content: Content };

const posts = getPosts({ type: "perspective", limit: 3 }).sort(
  (a, b) => sortOrder.indexOf(a.slug) - sortOrder.indexOf(b.slug),
);
---

<PostList
  title={content.perspective.title}
  subTitle={content.perspective.subTitle}
  posts={posts}
  sectionId="perspective"
/>
