---
interface Props {
  id: string;
  title: string;
}

const { id, title } = Astro.props;
---

<div id={id} class="fixed inset-0 z-100 hidden" role="dialog" aria-modal="true">
  <div class="fixed inset-0 bg-black/60 backdrop-blur-sm" data-action="closeModal"></div>
  <div class="fixed mx-auto md:w-3/5 inset-4 sm:inset-20 flex flex-col rounded-2xl shadow-2xl">
    <div class="flex items-center justify-between p-1 border-b bg-primary border-white/10">
      <h2 class="mt-1 ml-3 text-xl font-header font-bold uppercase text-white">{title}</h2>
      <button
        class="p-2 text-white/70 hover:text-white transition-colors"
        data-action="closeModal"
        aria-label="Close modal"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    <div class="flex-1 overflow-auto p-4 bg-primary-light">
      <slot />
    </div>
    <div class="flex justify-end gap-3 p-4 border-t border-white/10 bg-primary-light">
      <slot name="footer" />
    </div>
  </div>
</div>