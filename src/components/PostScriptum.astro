---
import type { Content } from "../lib/content";

const { content } = Astro.props as { content: Content };

---

<section class="container py-16 md:py-20 bg-grey-50" id="postScriptum">
  
  <h2 class="text-center font-header text-4xl font-semibold text-primary sm:text-5xl lg:text-6xl">
    {content.postScriptum.title}
  </h2>

  <p class="pt-6 text-center font-header text-xl font-medium text-black sm:text-2xl lg:text-3xl">
    {content.postScriptum.subTitle}
  </p>

  <div class="mx-auto w-full pt-5 text-center sm:w-2/3 lg:pt-6">
    {content.postScriptum.content.map(p => <p class="mt-2 font-body text-grey-10 sm:text-lg lg:text-xl">{p}</p>)}
  </div>
</section>