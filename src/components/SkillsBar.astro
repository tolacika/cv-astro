---
import type { Content } from "../lib/content";

const { content } = Astro.props as { content: Content };

const skills = content.intro.skills;
---

<section id="skills">
  {skills.map((skill, idx) => {
    const level = skill.proficiency;
    const extra = skill.learning && level < 80;
    const extraWidth = 80 - level;

    return (
      <div class={idx > 0 ? "pt-6" : ""}>
        <div class="flex items-end justify-between">
          <h4 class="font-body font-semibold uppercase text-black whitespace-pre-wrap">
            {skill.name}
          </h4>
          <h3 class="font-body text-3xl font-bold text-primary">
            {skill.proficiency}%
          </h3>
        </div>

        <div class="flex mt-2 h-3 w-full rounded-full bg-lila">
          <div
            class={`h-3 ${extra ? "rounded-l" : "rounded-full"} bg-primary`}
            style={`width: ${skill.proficiency}%`}
          ></div>

          {extra && (
            <div
              class="h-3 rounded-r bg-striped bg-2828 animate-move-stripe"
              style={`width: ${extraWidth}%`}
            ></div>
          )}
        </div>
      </div>
    );
  })}
</section>