---
import type { Content, ImageType } from "../lib/content";
import type { Post, PostContent } from "../lib/posts";
import HeroPost from "./HeroPost.astro";
import PostView from "./PostView.astro";

const { content, post } = Astro.props as { content: Content, post: Post };
const images = await post.images() as Record<string, ImageType>

---

<main>
  <HeroPost content={content} post={post} images={images} />

  <PostView content={content} post={post} images={images} />
</main>