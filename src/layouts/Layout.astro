---
import MainHead from "../components/MainHead.astro";
import type { MainHeadProps } from "../components/MainHead.astro";
import "../styles/global.css";
import LlmModal from "../components/LlmModal.astro";
import TagDetailModal from "../components/TagDetailModal.astro";

const { headProps } = Astro.props as { headProps: MainHeadProps };
---

<html lang="en">
  <head>
    <MainHead props={headProps} />
  </head>
  <body class="antialiased bg-primary">
    <LlmModal />
    <TagDetailModal />
    <div class="relative">
      <slot />
    </div>

    <script>
      function handleTagExplorerModal(el: Element, payload: string) {
        const elContent = el.querySelector(`#${el.id}-content`);
        if (!elContent) return;
        elContent.innerHTML = "";

        fetch(`/tag/${payload}-patrial.html`)
          .then((res) => res.text())
          .then((html) => {
            const parser = new DOMParser();
            const doc = parser.parseFromString(html, "text/html");
            elContent.innerHTML = doc.body.innerHTML;
          });
      }

      function handleScroll(target: string, e: PointerEvent) {
        const el = document.querySelector(target);

        if (el) {
          e.preventDefault();

          const header = document.querySelector("header > nav");
          const headerHeight = header ? header.clientHeight : 0;
          const buffer = 10;
          const elementPosition = el.getBoundingClientRect().top + window.scrollY;
          const offsetPosition = elementPosition - headerHeight - buffer;

          window.scrollTo({
            top: offsetPosition,
            behavior: "smooth",
          });
        }
      }

      function handleOpenModal(target: string, payload: string | undefined) {
        const el = document.querySelector(target);
        if (!el) return;
        if (el instanceof HTMLDialogElement) {
          el.showModal();
        } else if (el instanceof HTMLElement) {
          el.classList.remove("hidden");
        }

        if (payload) {
          handleTagExplorerModal(el, payload);
        }
      }

      function handleCloseModal() {
        document
          .querySelectorAll('*[role="dialog"]:not(.hidden)')
          .forEach((el) => {
            if (el instanceof HTMLDialogElement) {
              el.close();
            } else if (el instanceof HTMLElement) {
              el.classList.add("hidden");
            }
          });
      }

      function handleCollapse(target: string) {
        const targetEl = document.getElementById(target);
        if (!targetEl) return;

        const isExpanded = targetEl.classList.contains("expanded");

        // Close all other accordion elements
        document.querySelectorAll("[data-accordion].expanded").forEach((el) => {
          if (el instanceof HTMLElement && el.id !== target) {
            el.style.height = "0px";
            el.classList.remove("expanded");
          }
        });

        // Toggle the target accordion
        if (isExpanded) {
          targetEl.style.height = "0px";
          targetEl.classList.remove("expanded");
        } else {
          targetEl.style.height = targetEl.scrollHeight + "px";
          targetEl.classList.add("expanded");
        }
      }

      document.addEventListener("click", (e) => {
        const target = e.target;
        if (!(target instanceof HTMLElement || target instanceof SVGElement))
          return;

        const el = target.closest("[data-action]");
        if (!(el instanceof HTMLElement)) return;

        const action = el.dataset.action;
        const actionTarget = el.dataset.target;
        const actionPayload = el.dataset.payload;

        switch (action) {
          case "scroll":
            if (actionTarget) handleScroll(actionTarget, e);
            break;
          case "openModal":
            if (actionTarget) {
              if (
                document.querySelector(actionTarget) &&
                el.classList.contains("prevent-default")
              )
                e.preventDefault();
              handleOpenModal(actionTarget, actionPayload);
            }
            break;
          case "closeModal":
            handleCloseModal();
            break;
          case "collapse":
            if (target.hasAttribute("href") && target.getAttribute("href"))
              return;
            if (actionTarget) handleCollapse(actionTarget);
            break;
        }
      });
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") {
          document
            .querySelectorAll("[role=dialog]:not(.hidden)")
            .forEach((modal) => {
              modal.classList.add("hidden");
            });
        }
      });
    </script>
  </body>
</html>
