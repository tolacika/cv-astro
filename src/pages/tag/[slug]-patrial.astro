---
export const partial = true;

import { getContent, type Content } from "../../lib/content";
import ContentTag from "../../components/ContentTag.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  return (await getCollection("tagCollection")).map((tag) => {
    const slug = tag.data.slug ?? tag.id ?? "unknown";
    return {
      params: { slug },
      props: { tag },
    };
  });
}

const { tag } = Astro.props;

const content = getContent() as Content;
---

<ContentTag content={content} tag={tag} partial={true} />
