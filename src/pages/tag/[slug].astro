---
import { getContent, type Content } from "../../lib/content";
import BaseLayout from "../../layouts/Layout.astro"
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import ContentTag from "../../components/ContentTag.astro";
import authorImg from '../../assets/img/author-blue-hair.jpg';
import type { MainHeadProps } from "../../components/MainHead.astro";
import { getDefaultSeoProps } from "../../lib/seo";

export async function getStaticPaths() {
  const content = await getContent() as Content;
  
  return content.tags.map((tag) => ({
    params: { slug: tag.slug },
    props: { tag }
  }))
}

const { tag } = Astro.props;

const content = await getContent() as Content;

const headProps: MainHeadProps = getDefaultSeoProps(content);

headProps.ogImage = content.seo.cannonUrl + authorImg.src
---

<BaseLayout headProps={headProps}>
  <Navbar content={content} />

  <ContentTag content={content} tag={tag} />

	<Footer content={content} />
</BaseLayout>