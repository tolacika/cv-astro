---
import { getContent, type Content } from "../../lib/content";
import BaseLayout from "../../layouts/Layout.astro"
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import ContentPost from "../../components/ContentPost.astro";
import authorImg from '../../assets/img/author-blue-hair.jpg';
import type { MainHeadProps } from "../../components/MainHead.astro";
import { getDefaultSeoProps } from "../../lib/seo";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("postCollection");

  return posts.map((post) => ({
    params: { slug: post.data.slug ?? post.id },
    props: { post }
  }))
}

const { post } = Astro.props;

const content = getContent() as Content;

const headProps: MainHeadProps = getDefaultSeoProps(content, authorImg.src);
---

<BaseLayout headProps={headProps}>
  <Navbar content={content} />

  <ContentPost content={content} post={post} />

	<Footer content={content} />
</BaseLayout>